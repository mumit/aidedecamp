# Copy to .env and fill in. NEVER commit the filled-in .env.
# In deployment these come from a secrets store (GCP Secret Manager on the TELUS
# side), not a file on disk.

# --- Fuel iX (required) ---
# Long-lived bearer token, rotated manually. On 401 the app fails loudly asking
# for rotation rather than retrying.
FUELIX_TOKEN=

# --- Deployment identity ---
# personal | telus
ADC_DEPLOYMENT=personal
# mcp | direct_oauth  (how Workspace is reached; TELUS may require direct_oauth)
ADC_CONNECTOR_MODE=mcp

# --- Memory (Mem0 self-hosted) ---
ADC_MEM0_URL=http://localhost:8000

# --- Audit log ---
ADC_AUDIT_LOG_PATH=./audit.log.jsonl

# --- Slack (Phase 0+, Socket Mode) ---
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# --- Google Workspace (Phase 1+) ---
GOOGLE_PROJECT_ID=
# Path to OAuth client secret / service account is deployment-specific; keep it
# out of the repo and reference it here if you use file-based creds.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
