# Copy to .env and fill in. NEVER commit the filled-in .env.
# In deployment these come from a secrets store (GCP Secret Manager for both
# personal and TELUS — see docs/deployment.md), not a file on disk.

# --- Fuel iX (required) ---
# Long-lived bearer token, rotated manually. On 401 the app fails loudly asking
# for rotation rather than retrying.
FUELIX_TOKEN=

# --- Deployment identity ---
# personal | telus
ADC_DEPLOYMENT=personal
# mcp | direct_oauth  (how Workspace is reached; TELUS may require direct_oauth)
ADC_CONNECTOR_MODE=mcp
# The single identity this deployment acts as: memory/audit user_id, and the
# Gmail API "me" alias. Leave as "me" unless you have a specific reason to set
# an explicit address.
ADC_USER_ID=me

# --- Memory (Mem0 self-hosted; see packages/aidedecamp/deploy/mem0-compose.yml) ---
ADC_MEM0_URL=http://localhost:8000

# --- Audit log + durable state (see docs/deployment.md §10 for production paths) ---
ADC_AUDIT_LOG_PATH=./audit.log.jsonl
ADC_DB_PATH=./aidedecamp.db
ADC_GMAIL_WATCH_STATE_PATH=./gmail_watch_state.json
ADC_CHAT_SUBSCRIPTION_STATE_PATH=./chat_subscription_state.json
ADC_CALENDAR_WATCH_STATE_PATH=./calendar_watch_state.json
ADC_CALENDAR_SYNC_STATE_PATH=./calendar_sync_state.json

# --- Slack (Socket Mode) ---
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
# Where briefs/approval cards post proactively (a channel id). Leave unset to
# run without Slack's proactive posting; approval buttons still work either way.
ADC_SLACK_CHANNEL=

# --- Google Chat ---
# Where briefs/approval cards/conflict notifications post proactively (a space
# name, "spaces/AAAA..."). Leave unset to run without the Chat channel.
ADC_CHAT_SPACE=

# --- Google credentials ---
GOOGLE_PROJECT_ID=
# Path to a credentials JSON file: service account, or OAuth user credentials
# (from a one-time authorization flow — required for personal/consumer Gmail,
# since domain-wide delegation doesn't apply there). Leave unset to fall back
# to google.auth.default() (ADC) — the right choice for a TELUS deployment
# using a service account with domain-wide delegation. See docs/deployment.md §4.
ADC_GOOGLE_CREDENTIALS_FILE=

# --- Gmail ingestion (Pub/Sub) ---
ADC_GMAIL_PUBSUB_TOPIC=
ADC_GMAIL_PUBSUB_SUBSCRIPTION=

# --- Chat ingestion (Workspace Events API, Pub/Sub) ---
ADC_CHAT_PUBSUB_TOPIC=
ADC_CHAT_PUBSUB_SUBSCRIPTION=

# --- Chat card-click interactions (approve/reject only — edit's dialog-open
# click is answered synchronously by the republisher and never reaches this
# topic). The republisher's /chat-interaction route publishes here after
# verifying the request is genuinely from Google Chat; see rule 5 and
# docs/deployment.md §8/§12. ---
ADC_CHAT_INTERACTION_PUBSUB_TOPIC=
ADC_CHAT_INTERACTION_PUBSUB_SUBSCRIPTION=

# --- Calendar ingestion (the other source needing a real webhook — see rule 5
# and docs/deployment.md §8; ADC_CALENDAR_WEBHOOK_ADDRESS is the external thin
# republisher's HTTPS endpoint, not anything this process itself listens on) ---
ADC_CALENDAR_PUBSUB_TOPIC=
ADC_CALENDAR_PUBSUB_SUBSCRIPTION=
ADC_CALENDAR_WEBHOOK_ADDRESS=
ADC_CALENDAR_ID=primary
